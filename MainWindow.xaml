<Window x:Class="WpfSportolok.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sportolók" Height="500" Width="700">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="dgSportolok"
                  Grid.Row="0"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Név"
                                    Binding="{Binding Nev}" />
                <DataGridTextColumn Header="Pontszám"
                                    Binding="{Binding Pontszam}" />
                <DataGridTextColumn Header="Ország"
                                    Binding="{Binding Orszag}" />
            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Grid.Row="1" Margin="0,10,0,0">

            <TextBlock x:Name="txtAtlag" FontSize="14"/>
            <TextBlock x:Name="txtMagyarok" FontSize="14"/>
            <TextBlock x:Name="txtGyoztes" FontSize="14"/>
            <TextBlock x:Name="txtAlacsony" FontSize="14"/>
            <TextBlock x:Name="txtKeresett" FontSize="14"/>

            <Button Content="Elit versenyzők exportálása"
                    Width="220"
                    Height="35"
                    Margin="0,10,0,0"
                    Click="BtnExport_Click"/>

        </StackPanel>

    </Grid>
</Window>
